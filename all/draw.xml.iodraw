        <mxCell id="arrow1" value="API 调用/模型推理" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;" parent="1" source="llm_box" target="dify_box" edge="1">
          <mxGeometry relative="1" as="geometry" />
