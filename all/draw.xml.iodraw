      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="llm_group" value="外部 LLM 服务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f7ff;strokeColor=#1890ff;dashed=1;" parent="1" vertex="1">
