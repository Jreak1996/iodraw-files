        </mxCell>
        <mxCell id="infra_group" value="外部基础设施" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f0ff;strokeColor=#722ed1;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="200" y="440" width="640" height="160" as="geometry" />
